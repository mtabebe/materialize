# Tests for CREATE BRANCH / DROP BRANCH / SHOW BRANCHES / SHOW BRANCH STATUS.
# Phase 1: branch metadata is in-memory only; branched tables start empty.

mode cockroach

# Setup: create a source schema with some objects.
statement ok
CREATE SCHEMA src

statement ok
CREATE TABLE src.t1 (a INT, b TEXT)

statement ok
INSERT INTO src.t1 VALUES (1, 'hello'), (2, 'world')

# --- Basic lifecycle ---

statement ok
CREATE BRANCH my_branch FROM src

# SHOW BRANCHES returns (name, source_schema, status).
query TTT
SHOW BRANCHES
----
my_branch  src  active

# SHOW BRANCH STATUS returns (name, source_schema, status).
query TTT
SHOW BRANCH STATUS my_branch
----
my_branch  src  active

# --- Idempotency / duplicate protection ---

statement error schema 'my_branch' already exists
CREATE BRANCH my_branch FROM src

# --- DDL freeze on the source schema ---

statement error cannot alter schema "src" while it has an active branch "my_branch"
DROP SCHEMA src CASCADE

# --- Phase 1b: forked tables reflect source data at branch time ---

# my_branch.t1 was created as a forked table; source data is visible.
query IT rowsort
SELECT a, b FROM my_branch.t1
----
1  hello
2  world

# Writes to the branch table are visible in the branch.
statement ok
INSERT INTO my_branch.t1 VALUES (3, 'branch-only')

query IT rowsort
SELECT a, b FROM my_branch.t1
----
1  hello
2  world
3  branch-only

# Source table is unaffected by branch writes.
query IT rowsort
SELECT a, b FROM src.t1
----
1  hello
2  world

# Deletes in the branch do not affect the source.
statement ok
DELETE FROM my_branch.t1 WHERE a = 1

query IT rowsort
SELECT a, b FROM my_branch.t1
----
2  world
3  branch-only

query IT rowsort
SELECT a, b FROM src.t1
----
1  hello
2  world

# --- Additional tables in branch schema ---

statement ok
CREATE TABLE my_branch.t2 (x INT)

statement ok
INSERT INTO my_branch.t2 VALUES (42)

query I
SELECT x FROM my_branch.t2
----
42

# --- Multiple branches ---

statement ok
CREATE BRANCH branch2 FROM src

query TTT rowsort
SHOW BRANCHES
----
branch2    src  active
my_branch  src  active

# --- DROP BRANCH ---

statement ok
DROP BRANCH my_branch

query TTT
SHOW BRANCHES
----
branch2  src  active

# src is still frozen by branch2.
statement error cannot alter schema "src" while it has an active branch "branch2"
DROP SCHEMA src CASCADE

statement ok
DROP BRANCH branch2

# Now src is free.
statement ok
DROP SCHEMA src CASCADE

# --- IF EXISTS ---

statement ok
DROP BRANCH IF EXISTS nonexistent_branch

statement error branch "nonexistent_branch" does not exist
DROP BRANCH nonexistent_branch

# --- SHOW BRANCH STATUS for unknown branch ---

statement error unknown branch "no_such_branch"
SHOW BRANCH STATUS no_such_branch

# ══════════════════════════════════════════════════════════════════════════════
# Phase 2: materialized views are replicated into the branch
# ══════════════════════════════════════════════════════════════════════════════

statement ok
CREATE SCHEMA mv_src

statement ok
CREATE TABLE mv_src.items (id INT, val INT)

statement ok
INSERT INTO mv_src.items VALUES (1, 10), (2, 20), (3, 30)

statement ok
CREATE MATERIALIZED VIEW mv_src.total AS SELECT SUM(val) AS s FROM mv_src.items

# Source MV shows the initial sum.
query I
SELECT s FROM mv_src.total
----
60

# Create a branch — the MV is replicated into the branch.
statement ok
CREATE BRANCH mv_branch FROM mv_src

# Branch MV exists and shows the sum as of branch time.
query I
SELECT s FROM mv_branch.total
----
60

# Write to the source after branching — should NOT be visible in the branch MV.
statement ok
INSERT INTO mv_src.items VALUES (4, 40)

# Source MV sees the new row.
query I
SELECT s FROM mv_src.total
----
100

# Branch MV is isolated; it still reflects the state at branch time plus any
# branch-local writes (none so far).
query I
SELECT s FROM mv_branch.total
----
60

# Write into the branch table — branch MV should reflect this.
statement ok
INSERT INTO mv_branch.items VALUES (5, 50)

query I
SELECT s FROM mv_branch.total
----
110

# Source MV is unaffected by branch writes.
query I
SELECT s FROM mv_src.total
----
100

# DROP BRANCH drops the replicated MV along with the forked table.
statement ok
DROP BRANCH mv_branch

# Source MV is still intact.
query I
SELECT s FROM mv_src.total
----
100

# Cleanup.
statement ok
DROP SCHEMA mv_src CASCADE

# ══════════════════════════════════════════════════════════════════════════════
# Phase 2b: indexes are replicated into the branch
# ══════════════════════════════════════════════════════════════════════════════

statement ok
CREATE SCHEMA idx_src

statement ok
CREATE TABLE idx_src.data (k INT, v TEXT)

statement ok
INSERT INTO idx_src.data VALUES (1, 'a'), (2, 'b'), (3, 'c')

statement ok
CREATE INDEX idx_src_data_k ON idx_src.data (k)

# Create a branch — the index is replicated into the branch schema.
statement ok
CREATE BRANCH idx_branch FROM idx_src

# The forked table is readable via the branch index.
query IT rowsort
SELECT k, v FROM idx_branch.data
----
1  a
2  b
3  c

# Writes to the branch table are reflected in the branch index.
statement ok
INSERT INTO idx_branch.data VALUES (4, 'd')

query IT rowsort
SELECT k, v FROM idx_branch.data
----
1  a
2  b
3  c
4  d

# Source is unaffected.
query IT rowsort
SELECT k, v FROM idx_src.data
----
1  a
2  b
3  c

# DROP BRANCH removes the branch index along with the forked table.
statement ok
DROP BRANCH idx_branch

# Source index and table are intact.
query IT rowsort
SELECT k, v FROM idx_src.data
----
1  a
2  b
3  c

statement ok
DROP SCHEMA idx_src CASCADE

# ══════════════════════════════════════════════════════════════════════════════
# Phase 2c: cross-schema MV NOTICE
# ══════════════════════════════════════════════════════════════════════════════

statement ok
CREATE SCHEMA ref_data

statement ok
CREATE TABLE ref_data.multipliers (id INT, factor INT)

statement ok
INSERT INTO ref_data.multipliers VALUES (1, 100), (2, 200)

statement ok
CREATE SCHEMA cross_src

statement ok
CREATE TABLE cross_src.events (id INT, amount INT)

statement ok
INSERT INTO cross_src.events VALUES (1, 5), (2, 3)

# This MV joins cross_src.events (in-schema) with ref_data.multipliers (out-of-schema).
statement ok
CREATE MATERIALIZED VIEW cross_src.enriched AS
SELECT e.id, e.amount * m.factor AS result
FROM cross_src.events e
JOIN ref_data.multipliers m ON e.id = m.id

query II rowsort
SELECT id, result FROM cross_src.enriched
----
1  500
2  600

# CREATE BRANCH should emit a NOTICE for the cross-schema MV.
statement ok
CREATE BRANCH cross_branch FROM cross_src

# Branch MV is present and reflects state at branch time.
query II rowsort
SELECT id, result FROM cross_branch.enriched
----
1  500
2  600

# The branch MV reads live ref_data — inserting there is visible in the branch MV.
statement ok
INSERT INTO ref_data.multipliers VALUES (3, 300)

# Branch items table only has events 1 and 2 (forked at branch time), so the
# new multiplier row has no matching event and does not change the MV output.
query II rowsort
SELECT id, result FROM cross_branch.enriched
----
1  500
2  600

statement ok
DROP BRANCH cross_branch

statement ok
DROP SCHEMA cross_src CASCADE

statement ok
DROP SCHEMA ref_data CASCADE

# =============================================================================
# Phase 3: MERGE BRANCH
# =============================================================================

# --- Clean merge: branch adds new rows, no upstream changes ---

statement ok
CREATE SCHEMA merge_src

statement ok
CREATE TABLE merge_src.t (k INT, v TEXT)

statement ok
INSERT INTO merge_src.t VALUES (1, 'a'), (2, 'b')

statement ok
CREATE BRANCH merge_b FROM merge_src

# Write a new row only in the branch.
statement ok
INSERT INTO merge_b.t VALUES (3, 'c')

# MERGE BRANCH returns 0 conflict rows (result set is empty on success).
query TTTT
MERGE BRANCH merge_b INTO merge_src
----

# Source schema should now have all three rows.
query IT rowsort
SELECT k, v FROM merge_src.t
----
1  a
2  b
3  c

# Branch is now in Merged state.
query TTT
SHOW BRANCH STATUS merge_b
----
merge_b  merge_src  merged

statement ok
DROP BRANCH merge_b

statement ok
DROP SCHEMA merge_src CASCADE

# --- Error: merging a branch that does not exist ---

statement error branch "nonexistent" does not exist
MERGE BRANCH nonexistent INTO src

# --- Error: mismatched INTO schema ---

statement ok
CREATE SCHEMA mismatch_src

statement ok
CREATE SCHEMA wrong_schema

statement ok
CREATE BRANCH mismatch_b FROM mismatch_src

statement error branch "mismatch_b" was created from schema "mismatch_src", not "wrong_schema"
MERGE BRANCH mismatch_b INTO wrong_schema

statement ok
DROP BRANCH mismatch_b

statement ok
DROP SCHEMA wrong_schema CASCADE

statement ok
DROP SCHEMA mismatch_src CASCADE
