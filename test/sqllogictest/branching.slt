# Tests for the BRANCH DDL surface. The orchestration that actually creates
# a branch is gated behind plumbing not in this MVP slice; these tests pin
# the flag-off rejection (the user-facing default) and confirm that the
# four BRANCH statements parse and surface a clear error when the flag is
# off.

mode cockroach

# Default: the flag is off, so any BRANCH statement must error with a
# message naming the flag. The exact error path runs through the planner
# stub, which surfaces a `sql_bail!` mentioning `enable_branching`.

query error CREATE BRANCH.*enable_branching.*off
CREATE BRANCH nightly FROM SCHEMA public

query error DROP BRANCH.*enable_branching.*off
DROP BRANCH nightly

query error DROP BRANCH.*enable_branching.*off
DROP BRANCH IF EXISTS nightly

query error SHOW BRANCHES.*enable_branching.*off
SHOW BRANCHES

query error SHOW BRANCH STATUS.*enable_branching.*off
SHOW BRANCH STATUS nightly

# Turning the flag on lets CREATE BRANCH succeed end-to-end. The branch
# row lands durably, SHOW BRANCHES returns it, DROP BRANCH cleans up.

simple conn=mz_system,user=mz_system
ALTER SYSTEM SET enable_branching = on
----
COMPLETE 0

statement ok
CREATE BRANCH nightly FROM SCHEMA public

# DROP BRANCH IF EXISTS on a missing branch is a no-op.
statement ok
DROP BRANCH IF EXISTS does_not_exist

# DROP BRANCH on the real branch succeeds.
statement ok
DROP BRANCH nightly

# Dropping it again without IF EXISTS errors.
query error branch "nightly" does not exist
DROP BRANCH nightly

# Reset the flag so this file doesn't pollute later tests.

simple conn=mz_system,user=mz_system
ALTER SYSTEM RESET enable_branching
----
COMPLETE 0
